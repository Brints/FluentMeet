# General Settings
PROJECT_NAME="FluentMeet"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Security
SECRET_KEY="your-super-secret-key-here"
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
VERIFICATION_TOKEN_EXPIRE_HOURS=24

# Database (PostgreSQL)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fluentmeet
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/fluentmeet

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_EMAIL_CONSUMER_GROUP_ID=email-worker

# External Services
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
DEEPGRAM_API_KEY=
DEEPL_API_KEY=
VOICE_AI_API_KEY=
OPENAI_API_KEY=

# Storage (S3/Cloudinary)
CLOUDINARY_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# Email (SES/Mailgun/Resend)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM_ADDRESS=no-reply@fluentmeet.com
MAILGUN_TIMEOUT_SECONDS=10
FRONTEND_BASE_URL=http://localhost:3000
RESEND_API_KEY=
SES_SENDER_EMAIL=
